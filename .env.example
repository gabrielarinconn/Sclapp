# SCLAPP environment variables (example)
# Copy this file to .env and replace values with your own. Do not commit .env to Git.

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Database host
DB_HOST=localhost
# Database port
DB_PORT=5432
# Database name
DB_NAME=sclapp
# Database user
DB_USER=postgres
# Database password
DB_PASSWORD=your_postgres_password_here

# ---------------------------------------------------------------------------
# Application and security
# ---------------------------------------------------------------------------
# Secret key for JWT and session signing (use a strong random value in production)
SECRET_KEY=your_secret_key_here
# Optional: separate key for refresh tokens (defaults to SECRET_KEY if not set)
REFRESH_SECRET_KEY=optional_separate_key_for_refresh_tokens
# Set to true when serving over HTTPS in production
COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# CORS (allowed frontend origins, comma-separated)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:8000

# ---------------------------------------------------------------------------
# OpenAI (for job classification in scraping)
# ---------------------------------------------------------------------------
# OpenAI API key (leave empty to disable AI classification; scraping will use rule-based fallback)
OPENAI_API_KEY=your_openai_key_here
# Model name (optional; job classifier uses gpt-4o-mini by default)
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Brevo (email sending)
# ---------------------------------------------------------------------------
# Brevo API key for sending emails (leave empty to use simulation mode)
BREVO_API_KEY=your_brevo_key_here
# Sender email address shown in sent emails
BREVO_SENDER_EMAIL=sender@example.com
# Sender name shown in sent emails
BREVO_SENDER_NAME=SCLAPP
